[Unit]
Description=pyCluster country data refresh
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=pycluster
Group=pycluster
WorkingDirectory=/home/pycluster/pyCluster
ExecStart=/usr/local/bin/pycluster-python /home/pycluster/pyCluster/scripts/update_cty.py --config /home/pycluster/pyCluster/config/pycluster.toml
